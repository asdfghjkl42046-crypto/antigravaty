const { CourtEngine } = require('../../../src/engine/CourtEngine');

// 模擬玩家資料
const playerNoTrust = {
  name: '欠債窮光蛋',
  g: 100,
  trustFund: 0,
  totalTrials: 0,
  rp: 80,
  tags: [{ id: 999, text: '測試罪名', netIncome: 500, turn: 1, isResolved: false }]
};

const playerWithTrust = {
  name: '有錢避險家',
  g: 100,
  trustFund: 500,
  totalTrials: 0,
  rp: 80,
  tags: [{ id: 888, text: '測試罪名', netIncome: 500, turn: 1, isResolved: false }]
};

console.log('--- 模擬開始 ---');

// 模擬 1: 無信託基金，罰金 500 萬，剩餘現金應該是 100 - 500 = -400
const res1 = CourtEngine.applyTrialResolution(playerNoTrust, false, '測試罪名', 999, 'traditionalist', 1);
console.log(`[無信託] 初始 G: ${playerNoTrust.g}, 罰金後 G: ${res1.g} (預期應為 -400)`);

// 模擬 2: 有信託基金，罰金 500 萬，剩餘現金應該是 Math.max(0, 100 - 500) = 0
const res2 = CourtEngine.applyTrialResolution(playerWithTrust, false, '測試罪名', 888, 'traditionalist', 1);
console.log(`[有信託] 初始 G: ${playerWithTrust.g}, 罰金後 G: ${res2.g} (預期應為 0)`);

if (res1.g === -400 && res2.g === 0) {
  console.log('✅ 驗證成功：負債邏輯運作正確！');
} else {
  console.log('❌ 驗證失敗：邏輯與預期不符。');
}
